{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "jsx": "preserve",
        "types": [
            "node"
        ]
    },
    "include": [
        "src/renderer/**/*.ts",
        "src/renderer/**/*.d.ts",
        "src/renderer/**/*.vue"
    ]
}