{
    "name": "kunlungame",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.30.3",
    "type": "module",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "typecheck": "tsc --noEmit && vue-tsc --noEmit -p tsconfig.renderer.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "models:download": "tsx scripts/download-models.ts",
        "dialogue:smoke": "tsx scripts/run-dialogue-smoke.ts",
        "smoke:openai": "tsx scripts/run-openai-compatible-smoke.ts",
        "playthrough": "tsx scripts/run-mainline-playthrough.ts",
        "knowledge:compile": "tsx scripts/compile-knowledge.ts",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "lucide-vue-next": "^1.0.0",
        "node-llama-cpp": "^3.12.1",
        "vue": "^3.5.13",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@types/node": "^24.3.0",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitest/coverage-v8": "^3.2.4",
        "electron": "^35.3.0",
        "electron-vite": "^3.1.0",
        "happy-dom": "^20.9.0",
        "tsx": "^4.20.3",
        "typescript": "^5.9.2",
        "vite": "^5.4.19",
        "vitest": "^3.2.4",
        "vue-tsc": "^2.1.10"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "esbuild",
            "node-llama-cpp"
        ]
    }
}